generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VpnUser {
  id                        BigInt                      @id(map: "pk_users") @default(autoincrement())
  username                  String                      @unique(map: "ix_users_username") @db.VarChar(128)
  status                    userstatus
  usedTraffic               BigInt                      @map("used_traffic")
  dataLimit                 BigInt?                     @map("data_limit")
  createdAt                 DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  admin_id                  BigInt?
  data_limit_reset_strategy datalimitresetstrategy      @default(no_reset)
  sub_revoked_at            DateTime?                   @db.Timestamptz(6)
  note                      String?                     @db.VarChar(500)
  online_at                 DateTime?                   @db.Timestamptz(6)
  edit_at                   DateTime?                   @db.Timestamptz(6)
  on_hold_timeout           DateTime?                   @db.Timestamptz(6)
  on_hold_expire_duration   BigInt?
  auto_delete_in_days       Int?
  last_status_change        DateTime?                   @db.Timestamptz(6)
  expire                    DateTime?                   @db.Timestamptz(6)
  proxy_settings            Json                        @default("{}") @db.Json
  next_plans                next_plans[]
  node_user_usages          node_user_usages[]
  notification_reminders    notification_reminders[]
  user_subscription_updates user_subscription_updates[]
  user_usage_logs           user_usage_logs[]
  admins                    admins?                     @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_admin_id_admins")
  groups                    UsersGroupsAssociation[]

  @@map("users")
}

model UsersGroupsAssociation {
  userId   BigInt  @map("user_id")
  groupsId BigInt  @map("groups_id")
  group    Group   @relation(fields: [groupsId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_groups_association_groups_id_groups")
  user     VpnUser @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_users_groups_association_user_id_users")

  @@id([userId, groupsId], map: "pk_users_groups_association")
  @@map("users_groups_association")
}

model Group {
  id                          BigInt                        @id(map: "pk_groups") @default(autoincrement())
  name                        String                        @db.VarChar(64)
  isDisabled                  Boolean                       @default(false) @map("is_disabled")
  inbounds_groups_association inbounds_groups_association[]
  template_group_association  template_group_association[] @ignore
  users                       UsersGroupsAssociation[]

  @@map("groups")
}

model Node {
  id                        BigInt                  @id(map: "pk_nodes") @default(autoincrement())
  name                      String                  @unique(map: "uq_nodes_name") @db.VarChar(256)
  address                   String                  @db.VarChar(256)
  port                      Int
  status                    NodeStatus
  lastChange                DateTime?               @map("last_status_change") @db.Timestamptz(6)
  message                   String?                 @db.VarChar(1024)
  createdAt                 DateTime                @map("created_at") @db.Timestamptz(6)
  uplink                    BigInt
  downlink                  BigInt
  xray_version              String?                 @db.VarChar(32)
  usage_coefficient         Float                   @default(1.0)
  node_version              String?                 @db.VarChar(32)
  connection_type           nodeconnectiontype      @default(grpc)
  server_ca                 String                  @default("") @db.VarChar(2048)
  keep_alive                Int                     @default(0)
  core_config_id            BigInt?
  api_key                   String?                 @db.VarChar(36)
  data_limit                BigInt                  @default(0)
  data_limit_reset_strategy datalimitresetstrategy  @default(no_reset)
  reset_time                Int                     @default(-1)
  default_timeout           Int                     @default(10)
  internal_timeout          Int                     @default(15)
  api_port                  Int                     @default(62051)
  node_stats                NodeStats[]
  node_usage_reset_logs     node_usage_reset_logs[]
  node_usages               node_usages[]
  node_user_usages          node_user_usages[]
  core_configs              core_configs?           @relation(fields: [core_config_id], references: [id], onUpdate: NoAction, map: "nodes_ibfk_1")

  @@map("nodes")
}

model NodeStats {
  id        BigInt   @id(map: "pk_node_stats") @default(autoincrement())
  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  nodeId    BigInt   @map("node_id")
  memTotal  BigInt   @map("mem_total")
  memUsed   BigInt   @map("mem_used")
  cpuCores  Int      @map("cpu_cores")
  cpuUsage  Float    @map("cpu_usage")
  inSpeed   BigInt   @map("incoming_bandwidth_speed")
  outSpeed  BigInt   @map("outgoing_bandwidth_speed")
  nodes     Node     @relation(fields: [nodeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_node_stats_node_id_nodes")

  @@map("node_stats")
}

model admin_usage_logs {
  id                    BigInt   @id(map: "pk_admin_usage_logs") @default(autoincrement())
  admin_id              BigInt
  used_traffic_at_reset BigInt
  reset_at              DateTime @db.Timestamptz(6)
  admins                admins   @relation(fields: [admin_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_admin_usage_logs_admin_id_admins")
}

model admins {
  id                  BigInt             @id(map: "pk_admins") @default(autoincrement())
  username            String             @unique(map: "ix_admins_username") @db.VarChar(34)
  hashed_password     String             @db.VarChar(128)
  created_at          DateTime           @db.Timestamptz(6)
  is_sudo             Boolean            @default(false)
  password_reset_at   DateTime?          @db.Timestamptz(6)
  telegram_id         BigInt?
  discord_webhook     String?            @db.VarChar(1024)
  used_traffic        BigInt             @default(0)
  is_disabled         Boolean            @default(false)
  sub_template        String?            @db.VarChar(1024)
  sub_domain          String?            @db.VarChar(256)
  profile_title       String?            @db.VarChar(512)
  support_url         String?            @db.VarChar(1024)
  discord_id          BigInt?
  notification_enable Json?
  admin_usage_logs    admin_usage_logs[]
  users               VpnUser[]
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model core_configs {
  id                     BigInt   @id(map: "pk_core_configs") @default(autoincrement())
  created_at             DateTime @db.Timestamptz(6)
  name                   String   @db.VarChar(256)
  config                 Json     @db.Json
  exclude_inbound_tags   String?  @db.VarChar(2048)
  fallbacks_inbound_tags String?  @db.VarChar(2048)
  nodes                  Node[]
}

model hosts {
  id                       BigInt               @id(map: "pk_hosts") @default(autoincrement())
  remark                   String               @db.VarChar(256)
  address                  String               @db.VarChar(256)
  port                     Int?
  inbound_tag              String?              @db.VarChar(256)
  sni                      String?              @db.VarChar(1000)
  host                     String?              @db.VarChar(1000)
  security                 proxyhostsecurity    @default(inbound_default)
  fingerprint              proxyhostfingerprint @default(none)
  allowinsecure            Boolean?
  is_disabled              Boolean?
  path                     String?              @db.VarChar(256)
  random_user_agent        Boolean              @default(false)
  alpn                     String?              @default("none") @db.VarChar(14)
  use_sni_as_host          Boolean              @default(false)
  priority                 Int
  http_headers             Json?                @db.Json
  transport_settings       Json?                @db.Json
  mux_settings             Json?                @db.Json
  noise_settings           Json?                @db.Json
  fragment_settings        Json?                @db.Json
  status                   String?              @default("") @db.VarChar(60)
  ech_config_list          String?              @db.VarChar(512)
  vless_route              String?              @db.VarChar(4)
  pinned_peer_cert_sha256  String?              @db.VarChar(128)
  verify_peer_cert_by_name String?              @db.VarChar(1000)
  inbounds                 inbounds?            @relation(fields: [inbound_tag], references: [tag], map: "fk_hosts_inbound_tag_inbounds")
}

model inbounds {
  id                          BigInt                        @id(map: "pk_inbounds") @default(autoincrement())
  tag                         String                        @unique(map: "ix_inbounds_tag") @db.VarChar(256)
  hosts                       hosts[]
  inbounds_groups_association inbounds_groups_association[]
}

model inbounds_groups_association {
  inbound_id BigInt
  group_id   BigInt
  groups     Group    @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inbounds_groups_association_group_id_groups")
  inbounds   inbounds @relation(fields: [inbound_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inbounds_groups_association_inbound_id_inbounds")

  @@id([inbound_id, group_id], map: "pk_inbounds_groups_association")
}

model jwt {
  id         Int    @id(map: "pk_jwt") @default(autoincrement())
  secret_key String @db.VarChar(64)
}

model next_plans {
  id                    BigInt          @id(map: "pk_next_plans") @default(autoincrement())
  user_id               BigInt
  data_limit            BigInt
  expire                Int?
  add_remaining_traffic Boolean         @default(false)
  user_template_id      BigInt?
  users                 VpnUser         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_next_plans_user_id_users")
  user_templates        user_templates? @relation(fields: [user_template_id], references: [id], onUpdate: NoAction, map: "fk_next_plans_user_template_id_user_templates")

  @@index([user_template_id], map: "ix_next_plans_user_template_id")
}

model node_usage_reset_logs {
  id         BigInt   @id(map: "pk_node_usage_reset_logs") @default(autoincrement())
  created_at DateTime @db.Timestamptz(6)
  node_id    BigInt
  uplink     BigInt
  downlink   BigInt
  nodes      Node     @relation(fields: [node_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_node_usage_reset_logs_node_id_nodes")

  @@index([node_id, created_at], map: "ix_node_usage_reset_logs_node_id_created_at")
}

model node_usages {
  id         BigInt   @id(map: "pk_node_usages") @default(autoincrement())
  created_at DateTime @db.Timestamptz(6)
  node_id    BigInt?
  uplink     BigInt
  downlink   BigInt
  nodes      Node?    @relation(fields: [node_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_node_usages_node_id_nodes")

  @@unique([created_at, node_id], map: "uq_node_usages_created_at")
  @@index([created_at], map: "ix_node_usages_created_at")
}

model node_user_usages {
  id           BigInt   @id(map: "pk_node_user_usages") @default(autoincrement())
  created_at   DateTime @db.Timestamptz(6)
  user_id      BigInt
  node_id      BigInt?
  used_traffic BigInt
  nodes        Node?    @relation(fields: [node_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_node_user_usages_node_id_nodes")
  users        VpnUser  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_node_user_usages_user_id_users")

  @@unique([created_at, user_id, node_id], map: "uq_node_user_usages_created_at")
  @@index([created_at], map: "ix_node_user_usages_created_at")
  @@index([node_id, created_at], map: "ix_node_user_usages_node_id_created_at")
  @@index([user_id, created_at], map: "ix_node_user_usages_user_id_created_at")
}

model notification_reminders {
  id         BigInt       @id(map: "pk_notification_reminders") @default(autoincrement())
  user_id    BigInt
  type       remindertype
  expires_at DateTime?    @db.Timestamptz(6)
  created_at DateTime     @db.Timestamptz(6)
  threshold  Int?
  users      VpnUser      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_reminders_user_id_users")
}

model settings {
  id                    BigInt @id(map: "pk_settings") @default(autoincrement())
  telegram              Json   @db.Json
  discord               Json   @db.Json
  webhook               Json   @db.Json
  notification_settings Json   @db.Json
  notification_enable   Json   @db.Json
  subscription          Json   @db.Json
  general               Json   @db.Json
}

model system {
  id       BigInt @id(map: "pk_system") @default(autoincrement())
  uplink   BigInt
  downlink BigInt
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model template_group_association {
  user_template_id BigInt?
  group_id         BigInt?
  groups           Group?          @relation(fields: [group_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_template_group_association_group_id_groups")
  user_templates   user_templates? @relation(fields: [user_template_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_template_group_association_user_template_id_user_templates")

  @@ignore
}

model user_subscription_updates {
  id         BigInt   @id(map: "pk_user_subscription_updates") @default(autoincrement())
  user_id    BigInt
  created_at DateTime @db.Timestamptz(6)
  user_agent String   @db.VarChar(512)
  users      VpnUser  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_subscription_updates_user_id_users")
}

model user_templates {
  id                         BigInt                       @id(map: "pk_user_templates") @default(autoincrement())
  name                       String                       @unique(map: "uq_user_templates_name") @db.VarChar(64)
  data_limit                 BigInt
  expire_duration            BigInt
  username_prefix            String?                      @db.VarChar(20)
  username_suffix            String?                      @db.VarChar(20)
  extra_settings             Json?                        @db.Json
  status                     userstatuscreate             @default(active)
  reset_usages               Boolean                      @default(false)
  on_hold_timeout            Int?
  data_limit_reset_strategy  datalimitresetstrategy       @default(no_reset)
  is_disabled                Boolean                      @default(false)
  next_plans                 next_plans[]
  template_group_association template_group_association[] @ignore
}

model user_usage_logs {
  id                    BigInt   @id(map: "pk_user_usage_logs") @default(autoincrement())
  user_id               BigInt?
  used_traffic_at_reset BigInt
  reset_at              DateTime @db.Timestamptz(6)
  users                 VpnUser? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_usage_logs_user_id_users")

  @@index([user_id, reset_at], map: "ix_user_usage_logs_user_id_reset_at")
}

enum NodeStatus {
  connected
  connecting
  error
  disabled
  limited

  @@map("nodestatus")
}

enum datalimitresetstrategy {
  no_reset
  day
  week
  month
  year
}

enum nodeconnectiontype {
  grpc
  rest
}

enum proxyhostalpn {
  h3
  h3_h2          @map("h3,h2")
  h3_h2_http_1_1 @map("h3,h2,http/1.1")
  none
  h2
  http_1_1       @map("http/1.1")
  h2_http_1_1    @map("h2,http/1.1")
}

enum proxyhostfingerprint {
  none
  chrome
  firefox
  safari
  ios
  android
  edge
  v360 @map("360")
  qq
  random
  randomized
  randomizednoalpn
  unsafe
}

enum proxyhostsecurity {
  inbound_default
  none
  tls
}

enum proxytypes {
  VMess
  VLESS
  Trojan
  Shadowsocks
}

enum remindertype {
  expiration_date
  data_usage
}

enum userstatus {
  active
  disabled
  limited
  expired
  on_hold
}

enum userstatuscreate {
  active
  on_hold
}

model AppState {
  key   String @id
  value String

  @@map("app_state")
}
